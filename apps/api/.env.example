# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL connection string for Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mixmatch?schema=public"

# Auth
# Generate a secure secret with `openssl rand -hex 32` (must be ≥32 characters)
JWT_SECRET="change-me-to-a-32+character-long-random-string-abcdef1234567890"
JWT_EXPIRES_IN="1h"

# CORS
WEB_ORIGIN="http://localhost:3000"

# Stellar/Soroban Configuration
STELLAR_NETWORK=testnet
# RPC_URL must be a valid Soroban RPC endpoint (required for blockchain integration)
RPC_URL="https://soroban-testnet.stellar.org"
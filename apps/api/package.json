{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "pnpm run openapi:check && tsc",
    "lint": "eslint src/",
    "openapi:check": "node --import tsx ./scripts/check-openapi.ts",
    "openapi:generate": "node --import tsx ./scripts/generate-openapi.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-concurrency=1 tests/*.test.ts tests/**/*.test.ts"
  },
  "dependencies": {
    "@mixmatch/logger": "workspace:*",
    "@mixmatch/observability": "workspace:*",
    "@mixmatch/analytics": "workspace:*",
    "@mixmatch/env-manifest": "workspace:*",
    "@mixmatch/types": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.5",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mixmatch/config": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.97",
    "@types/node": "^20.10.0",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}

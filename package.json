{
  "name": "mixmatch-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "pnpm -r --if-present run test",
    "clean": "turbo run clean",
    "bootstrap": "node scripts/bootstrap.js",
    "bootstrap:validate": "node scripts/bootstrap.js --validate-only",
    "bootstrap:partial": "node scripts/bootstrap.js --partial"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.3.0",
    "prettier": "^3.1.0"
  },
  "packageManager": "pnpm@8.15.0"
}
